{
  "processes": [
    {
      "name": "grass_spread",
      "types": ["random"],
      "interval": 2,
      "offset": 0,
      "repeat": 10,
      "block": "dirt",
      "above": "air",
      "beside": "grass",
      "set_block": "grass"
    },
    {
      "name": "grass_die",
      "types": ["ticked", "world_gen"],
      "block": "grass",
      "above": "air",
      "invert_above": true,
      "set_block": "dirt"
    },
    {
      "name": "water_flow_down",
      "types": ["ticked"],
      "block": "air",
      "above": "water",
      "set_block": "water"
    },
    {
      "name": "water_merge",
      "types": ["ticked"],
      "block": "air",
      "beside": "water",
      "beside_min": 2,
      "set_block": "water"
    }
  ]
}