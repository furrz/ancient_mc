{
  "processes": [
    {
      "name": "grass_spread",
      "type": "random",
      "interval": 2,
      "offset": 0,
      "repeat": 10,
      "block": "dirt",
      "above": "air",
      "beside": "grass",
      "set_block": "grass"
    },
    {
      "name": "grass_die",
      "type": "ticked",
      "block": "grass",
      "above": "air",
      "invert_above": true,
      "set_block": "dirt"
    },
    {
      "name": "water_flow_down",
      "type": "ticked",
      "block": "air",
      "above": "water",
      "set_block": "water"
    }
  ]
}